import pandas as pd

rf = pd.read_csv(
    r'C:\Users\USER\Downloads\nutr.csv',
    low_memory=False
)

print("Shape:")
print(rf.shape)

print("\nColumn Names:")
print(rf.columns)

print("\nData Types:")
print(rf.dtypes)

print("\nFirst 5 Rows:")
